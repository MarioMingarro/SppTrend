library(rnaturalearth)
# 2. Definir ruta de destino
dest_folder <- "inst/extdata"
if (!dir.exists(dest_folder)) dir.create(dest_folder, recursive = TRUE)
dest_path <- file.path(dest_folder, "ne_land.shp")
message("Descargando mapa de Natural Earth (Escala 1:50m)...")
# 3. Descargar la capa como objeto 'sf'
# 'medium' corresponde a la escala 1:50m
world_sf <- rnaturalearth::ne_download(
scale = 50,
type = "land",
category = "physical",
returnclass = "sf"
)
# 4. Guardar en extdata
# 'delete_dsn = TRUE' permite sobreescribir si ya existe
message("Guardando archivos en: ", dest_path)
sf::st_write(world_sf, dest_path, delete_dsn = TRUE, quiet = FALSE)
# 5. Verificación final
files <- list.files(dest_folder, pattern = "ne_land")
cat("\nArchivos generados en inst/extdata:\n")
print(files)
size_mb <- sum(file.size(file.path(dest_folder, files))) / 1024^2
cat("\nTamaño total del conjunto: ", round(size_mb, 2), " MB\n")
