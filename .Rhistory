# 1. Cargar librerías necesarias
# install.packages("rmapshaper")
# install.packages("terra")
library(terra)
library(rmapshaper)
install.packages("rmapshaper")
# 1. Cargar librerías necesarias
# install.packages("rmapshaper")
# install.packages("terra")
library(terra)
library(rmapshaper)
# 2. Definir rutas (Ajusta el nombre de tu archivo si es necesario)
# Buscamos la ruta original dentro de tu estructura de desarrollo
path_original <- "inst/extdata/ne_land.shp"
path_destino  <- "inst/extdata/ne_land_1.shp"
if (file.exists(path_original)) {
message("Cargando capa original...")
world_original <- terra::vect(path_original)
# 3. Simplificar la geometría
# keep = 0.05 significa que mantendrá solo el 5% de los puntos originales.
# Esto suele ser más que suficiente para mapas globales de este tipo.
message("Simplificando geometría (manteniendo el 5% de los vértices)...")
world_simple <- rmapshaper::ms_simplify(world_original, keep = 0.05, keep_shapes = TRUE)
# 4. Guardar la nueva capa
message("Guardando capa simplificada en: ", path_destino)
terra::writeVector(world_simple, path_destino, overwrite = TRUE)
# 5. Comparar tamaños
size_orig <- file.size(path_original) / 1024^2
size_dest <- file.size(path_destino) / 1024^2
cat("\n--- Resumen de reducción ---\n")
cat("Tamaño Original: ", round(size_orig, 2), " MB\n")
cat("Tamaño Nuevo:    ", round(size_dest, 2), " MB\n")
cat("Reducción del:   ", round((1 - size_dest/size_orig) * 100, 1), "%\n")
} else {
stop("No se encontró el archivo original en la ruta especificada.")
}
# 1. Cargar librerías necesarias
# install.packages(c("terra", "rmapshaper", "sf"))
library(terra)
library(rmapshaper)
library(sf)
# 2. Definir rutas
path_original <- "inst/extdata/ne_land.shp"
path_destino  <- "inst/extdata/ne_land_1.shp"
if (file.exists(path_original)) {
message("Cargando capa original...")
world_original <- terra::vect(path_original)
# 3. Convertir a sf para que rmapshaper lo entienda
message("Convirtiendo a sf y simplificando...")
world_sf <- sf::st_as_sf(world_original)
# Simplificar (keep = 0.05 es el 5%)
world_sf_simple <- rmapshaper::ms_simplify(world_sf, keep = 0.05, keep_shapes = TRUE)
# 4. Convertir de nuevo a terra (SpatVector)
world_simple <- terra::vect(world_sf_simple)
# 5. Guardar la nueva capa
message("Guardando capa simplificada en: ", path_destino)
terra::writeVector(world_simple, path_destino, overwrite = TRUE)
# Comparar tamaños
size_orig <- file.size(path_original) / 1024^2
size_dest <- file.size(path_destino) / 1024^2
cat("\n--- Resumen de reducción ---\n")
cat("Tamaño Original: ", round(size_orig, 2), " MB\n")
cat("Tamaño Nuevo:    ", round(size_dest, 2), " MB\n")
cat("Reducción del:   ", round((1 - size_dest/size_orig) * 100, 1), "%\n")
} else {
stop("No se encontró el archivo original en la ruta: ", path_original)
}
# 1. Cargar librerías
# install.packages(c("terra", "rnaturalearth"))
library(terra)
library(rnaturalearth)
# 2. Definir ruta de destino en tu paquete
dest_folder <- "inst/extdata"
if (!dir.exists(dest_folder)) dir.create(dest_folder, recursive = TRUE)
dest_path <- file.path(dest_folder, "ne_land.shp")
message("Descargando mapa de Natural Earth...")
# 3. Descargar la capa (tierra a escala 110m)
# Usamos returnclass = "sv" para obtener directamente un SpatVector de terra
world <- rnaturalearth::ne_download(
scale = 110,
type = "land",
category = "physical",
returnclass = "sv"
)
# 4. Guardar en extdata
message("Guardando en: ", dest_path)
terra::writeVector(world, dest_path, overwrite = TRUE)
# 5. Verificar tamaño
file_size <- file.size(dest_path) / 1024 # KB
cat("\nProceso finalizado.\n")
cat("Archivo guardado: ", dest_path, "\n")
cat("Tamaño del archivo: ", round(file_size, 2), " KB\n")
# Nota: Natural Earth descarga varios archivos (.shp, .dbf, .shx, .prj)
# terra::writeVector se encarga de crearlos todos automáticamente.
